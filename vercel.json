{
  "version": 2,
  "name": "y2mate-auto-request",
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    }
  ],
  "env": {
    "DELAY_MIN_MS": "1000",
    "DELAY_MAX_MS": "5000",
    "MAX_RETRIES": "3",
    "REQUEST_TIMEOUT_MS": "30000",
    "ROTATE_USER_AGENT": "true",
    "ROTATE_REFERER": "true"
  }
}
